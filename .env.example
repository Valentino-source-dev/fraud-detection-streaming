# ── Broker / Networking ──
KAFKA_BROKER=redpanda:9092
KAFKA_TOPIC=transactions

# ── Generator ──
REPLAY_SPEED=10
BATCH_SIZE=32
DATA_PATH=/data/creditcard.csv

# ── Consumer ──
CONSUMER_GROUP=fraud-detector
SCORE_THRESHOLD=0.5
METRICS_PORT=8000
MODEL_CHECK_INTERVAL_SEC=300

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fraud_detection
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud_secret_change_me

# ── MLflow ──
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=fraud-detector
MLFLOW_MODEL_STAGE=Production
