{
  "uid": "fraud-detection-main",
  "title": "Fraud Detection — Real-Time Pipeline",
  "description": "Live monitoring of the fraud detection streaming pipeline",
  "tags": ["fraud", "streaming", "ml"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Transactions / sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(transactions_processed_total[1m])",
          "legendFormat": "tx/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Fraud Rate (%)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "fraud_rate_ratio * 100",
          "legendFormat": "fraud %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Frauds Detected",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "predictions_total{prediction=\"fraud\"}",
          "legendFormat": "frauds"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Legitimate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "predictions_total{prediction=\"legit\"}",
          "legendFormat": "legit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput — Predictions over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(predictions_total{prediction=\"legit\"}[1m])",
          "legendFormat": "legit/s"
        },
        {
          "expr": "rate(predictions_total{prediction=\"fraud\"}[1m])",
          "legendFormat": "fraud/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fraud/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "legit/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Inference Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(inference_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(inference_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(inference_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Consumer Lag (messages behind)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "consumer_lag",
          "legendFormat": "lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Prediction Distribution",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "predictions_total",
          "legendFormat": "{{ prediction }}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fraud" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "legit" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 9,
      "type": "heatmap",
      "title": "Anomaly Score Distribution",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "expr": "rate(anomaly_score_distribution_bucket[5m])",
          "legendFormat": "{{ le }}"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Model Version",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "active_model_info",
          "legendFormat": "{{ version }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Avg Latency (ms)",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 18 },
      "targets": [
        {
          "expr": "rate(inference_latency_seconds_sum[5m]) / rate(inference_latency_seconds_count[5m]) * 1000",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
